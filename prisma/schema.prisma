generator client {
  provider = "prisma-client-js"
}

// Datasource com os nomes de variavel que a integracao Vercel + Neon injeta
// automaticamente no projeto:
//   POSTGRES_PRISMA_URL      -> conexao "pooled" (usada pelo app em runtime)
//   POSTGRES_URL_NON_POOLING -> conexao direta   (usada por migrations/db push)
datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

enum MediaType {
  IMAGE
  GIF
  VIDEO
  AUDIO
  TEXT
  EMBED
}

enum ActionType {
  SHOW
  CLEAR
  UPLOAD
  LIVE
}

// Conta de mod com cadastro proprio (email + usuario + senha). O login usa
// usuario (ou email) + senha; a recuperacao usa SO o email. A senha e guardada
// como hash (scrypt) — nunca em texto puro. Convive com o MOD_ACCOUNTS (env)
// como fallback para as contas antigas.
model User {
  id           String               @id @default(cuid())
  email        String               @unique // sempre minusculo
  username     String               @unique // sempre minusculo
  passwordHash String
  createdAt    DateTime             @default(now())
  resetTokens  PasswordResetToken[]
}

// Token de "esqueci a senha": aleatorio, guardado como HASH (sha256), de uso
// unico e com validade curta. Cada pedido novo invalida os anteriores do
// usuario (sempre um link novo). O token em claro so existe no link do email.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// Biblioteca de midias (secao 2.5): apenas metadados; o binario fica no
// armazenamento de arquivos (Vercel Blob), aqui guardamos so a URL.
model Media {
  id        String    @id @default(cuid())
  name      String
  type      MediaType
  url       String
  tags      String[]  @default([])
  createdBy String // nome do mod que cadastrou (self-identificado no login)
  createdAt DateTime  @default(now())

  @@index([type])
  @@index([tags])
}

// Estado atual do overlay (linha unica, id = "current"). Serve para o
// overlay recuperar o que esta na tela ao (re)carregar no OBS, ja que o
// Pusher nao repete eventos passados. Sem isso, um browser source que
// reconecta/atualiza fica em branco ate o proximo disparo.
model OverlayState {
  id        String     @id
  streamer  String     @default("") // streamer dono do overlay (overlay compartilhado)
  owner     String     @default("") // mod que colocou o item (mesa individual por mod)
  mediaId   String?
  url       String?
  text      String? // conteudo do item de texto (type = TEXT)
  type      MediaType?
  x         Float      @default(0.5)
  y         Float      @default(0.5)
  scale     Float      @default(1)
  scaleY    Float? // altura como fracao da tela; nulo = altura natural (sem distorcer)
  volume    Float      @default(1) // volume do audio/video (0..1)
  muted     Boolean    @default(false) // som mutado?
  hidden    Boolean    @default(false) // oculto (nao mostra no overlay nem toca som)
  sticky    Boolean    @default(false)
  expiresAt DateTime? // para "flash" (nao-sticky): some sozinho depois disso
  updatedAt DateTime   @updatedAt

  @@index([streamer])
  @@index([owner])
}

// Log de disparos (secao 2.5 / 7): auditoria de cada acao sensivel.
// Guarda um snapshot do nome da midia para o historico nao quebrar caso a
// midia seja removida depois.
model AuditLog {
  id         String     @id @default(cuid())
  action     ActionType
  actor      String // nome do mod que realizou a acao
  mediaId    String?
  mediaName  String?
  durationMs Int?
  createdAt  DateTime   @default(now())

  @@index([createdAt])
}
