generator client {
  provider = "prisma-client-js"
}

// Datasource com os nomes de variavel que a integracao Vercel + Neon injeta
// automaticamente no projeto:
//   POSTGRES_PRISMA_URL      -> conexao "pooled" (usada pelo app em runtime)
//   POSTGRES_URL_NON_POOLING -> conexao direta   (usada por migrations/db push)
datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

enum MediaType {
  IMAGE
  GIF
  VIDEO
  AUDIO
}

enum ActionType {
  SHOW
  CLEAR
  UPLOAD
  LIVE
}

// Biblioteca de midias (secao 2.5): apenas metadados; o binario fica no
// armazenamento de arquivos (Vercel Blob), aqui guardamos so a URL.
model Media {
  id        String    @id @default(cuid())
  name      String
  type      MediaType
  url       String
  tags      String[]  @default([])
  createdBy String // nome do mod que cadastrou (self-identificado no login)
  createdAt DateTime  @default(now())

  @@index([type])
  @@index([tags])
}

// Estado atual do overlay (linha unica, id = "current"). Serve para o
// overlay recuperar o que esta na tela ao (re)carregar no OBS, ja que o
// Pusher nao repete eventos passados. Sem isso, um browser source que
// reconecta/atualiza fica em branco ate o proximo disparo.
model OverlayState {
  id        String     @id
  mediaId   String?
  url       String?
  type      MediaType?
  x         Float      @default(0.5)
  y         Float      @default(0.5)
  scale     Float      @default(1)
  sticky    Boolean    @default(false)
  expiresAt DateTime? // para "flash" (nao-sticky): some sozinho depois disso
  updatedAt DateTime   @updatedAt
}

// Log de disparos (secao 2.5 / 7): auditoria de cada acao sensivel.
// Guarda um snapshot do nome da midia para o historico nao quebrar caso a
// midia seja removida depois.
model AuditLog {
  id         String     @id @default(cuid())
  action     ActionType
  actor      String // nome do mod que realizou a acao
  mediaId    String?
  mediaName  String?
  durationMs Int?
  createdAt  DateTime   @default(now())

  @@index([createdAt])
}
