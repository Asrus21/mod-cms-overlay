# =========================================================================
#  Mod CMS Overlay — variaveis de ambiente
#  Em producao (Vercel) essas variaveis sao configuradas no painel do projeto.
#  Para rodar local, copie este arquivo para .env.local e preencha.
# =========================================================================

# --- Banco de dados (Vercel Postgres / Neon) ---
# A integracao Neon no projeto Vercel injeta estas duas automaticamente.
# Para rodar local, cole aqui as strings que a Neon te da (pode usar a mesma
# nas duas se o seu Postgres local nao tiver pooling).
POSTGRES_PRISMA_URL="postgresql://user:pass@host/db?sslmode=require&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgresql://user:pass@host/db?sslmode=require"

# --- Acesso dos moderadores ---
# Contas dos mods (cada um tem nome + senha e a SUA propria mesa/overlay).
# JSON com uma lista de {name, password}. Defina no projeto Vercel — as senhas
# ficam SO no ambiente, nunca no codigo. Exemplo (troque os valores):
MOD_ACCOUNTS='[{"name":"mod1","password":"DEFINA_UMA_SENHA"},{"name":"mod2","password":"DEFINA_UMA_SENHA"}]'
# Segredo usado para assinar o cookie de sessao. Gere com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET="troque-por-um-segredo-aleatorio-longo"

# --- Camada de tempo real (Pusher) ---
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="us2"
# Estes dois sao expostos ao navegador (painel + overlay). Use os MESMOS
# valores de PUSHER_KEY / PUSHER_CLUSTER acima.
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="us2"

# --- Armazenamento de arquivos (Vercel Blob) ---
# A store Blob criada no projeto Vercel injeta esta variavel automaticamente.
BLOB_READ_WRITE_TOKEN=""

# --- Feed ao vivo do mod (VDO.Ninja) ---
# Nome da "sala" do seu canal. Use um valor aleatorio e nao-obvio (ele
# funciona como um segredo). Deixe vazio para desativar o recurso de ao vivo.
VDO_ROOM=""
# Senha opcional da sala (recomendado). Se preenchida, todos os links a usam.
VDO_PASSWORD=""

# --- Fundo da mesa via Twitch (opcional) ---
# Nome do canal da Twitch. Se preenchido, o painel pode usar a propria
# transmissao da Twitch como fundo da mesa (o streamer nao precisa abrir nada).
TWITCH_CHANNEL=""

# --- Cadastro/login e recuperacao de senha por email ---
# Os usuarios se cadastram (email + usuario + senha) e o "esqueci a senha"
# envia um link por email. O envio usa o Resend (https://resend.com):
#   1) Crie uma conta no Resend e gere uma API Key.
#   2) (Producao) Verifique um dominio e use um remetente dele em RESET_FROM_EMAIL.
#      Sem dominio verificado, use "onboarding@resend.dev" (so entrega para o
#      email da sua propria conta Resend — util para testar).
RESEND_API_KEY=""
RESET_FROM_EMAIL="onboarding@resend.dev"

# Codigo de convite para fechar o cadastro (OPCIONAL). Se definido, so quem
# souber o codigo consegue criar conta. Deixe vazio para cadastro aberto.
# ATENCAO: com cadastro aberto, qualquer um pode criar conta de mod.
REGISTER_INVITE_CODE=""
