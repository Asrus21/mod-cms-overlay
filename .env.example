# --- Banco de dados ---
# Postgres (ex: Vercel Postgres, Neon, Supabase)
DATABASE_URL="postgresql://user:password@host:5432/mod_cms_overlay"

# --- Autenticacao (Twitch OAuth via NextAuth) ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="gere-com: openssl rand -base64 32"
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""

# Canal cujo mod-status sera validado (Twitch user id do broadcaster, numerico)
TWITCH_BROADCASTER_ID=""

# --- Camada de tempo real (Pusher) ---
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="us2"
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="us2"

# --- Armazenamento de arquivos (Vercel Blob) ---
BLOB_READ_WRITE_TOKEN=""
